# ── Flash Motion — Environment Variables ──

# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://flashmotion:flashmotion@localhost:5432/flashmotion

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-openssl-rand-base64-48
JWT_EXPIRES_IN=7d

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=flash-motion
S3_REGION=us-east-1

# LLM — OpenRouter (preferred)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# LLM — Ollama fallback (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# LLM mode: "openrouter" | "ollama" | "auto" (try openrouter first, fallback ollama)
LLM_MODE=auto

# TTS (optional)
TTS_ENGINE=none
# TTS_ENGINE=piper | elevenlabs
ELEVENLABS_API_KEY=

# Render
MAX_CONCURRENT_RENDERS=1
RENDER_TIMEOUT_MS=300000
TEMP_DIR=/tmp/flash-motion

# Upload limits
MAX_FILE_SIZE_MB=8
MAX_ASSETS_PER_PROJECT=20

# Retention
RETENTION_DAYS=30
