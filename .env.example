# ── Flash Motion — Environment Variables ──

# ═══════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ═══════════════════════════════════════════
# DOCKER / DEPLOYMENT
# ═══════════════════════════════════════════
# Used by docker-compose.prod.yml + Caddy for HTTPS
DB_USER=flashmotion
DB_PASSWORD=change-me
API_DOMAIN=api.finablasolution.cloud

# ═══════════════════════════════════════════
# DATABASE (PostgreSQL)
# ═══════════════════════════════════════════
DATABASE_URL=postgresql://flashmotion:flashmotion@localhost:5432/flashmotion

# ═══════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════
# JWT AUTHENTICATION
# ═══════════════════════════════════════════
JWT_SECRET=change-me-in-production-use-openssl-rand-base64-48
JWT_EXPIRES_IN=7d

# ═══════════════════════════════════════════
# MINIO / S3 STORAGE
# ═══════════════════════════════════════════
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=flash-motion
S3_REGION=us-east-1

# ═══════════════════════════════════════════
# LLM (Storyboard Generation)
# ═══════════════════════════════════════════
# Mode: "openrouter" | "ollama" | "auto" (try openrouter first, fallback ollama)
LLM_MODE=auto

# OpenRouter (cloud — recommended for production)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# Ollama (local — free, requires local install)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ═══════════════════════════════════════════
# TTS — Text-to-Speech (optional)
# ═══════════════════════════════════════════
# Engine: "none" | "elevenlabs" | "piper"
TTS_ENGINE=none

# ElevenLabs (cloud — high quality)
ELEVENLABS_API_KEY=

# Piper (local — free, requires piper binary)
PIPER_MODEL=fr_FR-upmc-medium

# ═══════════════════════════════════════════
# EMAIL — SMTP (optional)
# ═══════════════════════════════════════════
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@flashmotion.dev

# ═══════════════════════════════════════════
# RENDER WORKER
# ═══════════════════════════════════════════
MAX_CONCURRENT_RENDERS=1
RENDER_TIMEOUT_MS=300000
TEMP_DIR=/tmp/flash-motion

# ═══════════════════════════════════════════
# UPLOAD LIMITS
# ═══════════════════════════════════════════
MAX_FILE_SIZE_MB=8
MAX_ASSETS_PER_PROJECT=20

# ═══════════════════════════════════════════
# RETENTION
# ═══════════════════════════════════════════
RETENTION_DAYS=30

# ═══════════════════════════════════════════
# NETLIFY (frontend only)
# ═══════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# In production: NEXT_PUBLIC_API_URL=https://api.finablasolution.cloud/api
BACKEND_URL=http://localhost:4000
