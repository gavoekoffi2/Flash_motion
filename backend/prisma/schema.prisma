generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  name           String?
  role           Role      @default(USER)
  plan           Plan      @default(FREE)
  avatarUrl      String?
  resetToken     String?
  resetTokenExp  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  projects       Project[]
  quota          Quota?

  @@index([resetToken])
}

model Quota {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  llmCallsToday   Int      @default(0)
  llmCallsLimit   Int      @default(20)
  rendersToday    Int      @default(0)
  rendersLimit    Int      @default(5)
  storageUsedMb   Float    @default(0)
  storageLimitMb  Float    @default(500)
  lastResetAt     DateTime @default(now())
}

model Project {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  script      String        @db.Text
  template    String        @default("HeroPromo")
  aspectRatio String        @default("9:16")
  status      ProjectStatus @default(DRAFT)
  storyboard  Json?
  brandConfig Json?
  shareToken  String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  assets      Asset[]
  renderJobs  RenderJob[]

  @@index([userId])
}

model Asset {
  id         String    @id @default(uuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type       AssetType
  filename   String
  mimeType   String
  sizeMb     Float
  s3Key      String
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([projectId])
}

model RenderJob {
  id         String      @id @default(uuid())
  projectId  String
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status     RenderStatus @default(QUEUED)
  engine     String       @default("remotion")
  outputKey  String?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime    @default(now())

  @@index([projectId])
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum ProjectStatus {
  DRAFT
  STORYBOARD_READY
  RENDERING
  DONE
  FAILED
}

enum AssetType {
  IMAGE
  LOGO
  AUDIO
  FONT
}

enum RenderStatus {
  QUEUED
  RENDERING
  UPLOADING
  DONE
  FAILED
}
